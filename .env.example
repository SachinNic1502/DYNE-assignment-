# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration (Railway Template)
DATABASE_URL="postgresql://${PGUSER}:${POSTGRES_PASSWORD}@${RAILWAY_TCP_PROXY_DOMAIN}:${RAILWAY_TCP_PROXY_PORT}/${PGDATABASE}"

# Individual Database Variables
PGUSER=
POSTGRES_PASSWORD=
RAILWAY_TCP_PROXY_DOMAIN=
RAILWAY_TCP_PROXY_PORT=
PGDATABASE=

# Prisma Configuration
PRISMA_CLIENT_ENGINE_TYPE="library"

# Public Environment Variables
NEXT_PUBLIC_APP_NAME="Dyne Analytics Dashboard"
